FROM nginx:alpine

# Verzeichnis für die statischen Dateien erstellen
WORKDIR /var/www/html

# Die Nginx-Konfiguration kopieren
COPY docker/nginx.conf /etc/nginx/conf.d/default.conf

# Den public-Ordner kopieren (wichtig für try_files und Pfad-Validierung)
COPY public /var/www/html/public

# Berechtigungen anpassen
RUN chown -R nginx:nginx /var/www/html